<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Cursos</h2>
    <a href="/major/create" class="btn btn-primary">Novo Curso</a>
  </div>
  <table class="table table-hover table-bordered">
    <thead class="table-dark">
      <tr>
        <th>Código</th>
        <th>Nome</th>
        <th>Descrição</th>
        <th>Opções</th>
      </tr>
    </thead>
    <tbody>
      {{#each majors}}
      <tr>
        <td>{{this.code}}</td>
        <td>{{this.name}}</td>
        <td>{{this.description}}</td>
        <td>
          <a href="/major/read/{{this.id}}" class="btn btn-sm btn-info">Ver</a>
          <a href="/major/update/{{this.id}}" class="btn btn-sm btn-warning">Editar</a>
          <form action="/major/delete/{{this.id}}" method="post" class="d-inline"
            onsubmit="return confirm('Excluir {{this.name}}?')">
            <button type="submit" class="btn btn-sm btn-danger">Excluir</button>
          </form>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>

<div class="container mt-4" style="max-width: 600px">
  <h2 class="mb-4">Nova Partida</h2>
  <form action="/game-session/create" method="post">
    <div class="mb-3">
      <label for="userId" class="form-label">Usuário</label>
      <select class="form-select" id="userId" name="userId" required>
        <option value="" disabled selected>Selecione um usuário</option>
        {{#each users}}
        <option value="{{id}}">{{name}}</option>
        {{/each}}
      </select>
    </div>
    <div class="mb-3">
      <label for="score" class="form-label">Pontuação</label>
      <input type="number" class="form-control" id="score" name="score" min="0" required>
    </div>
    <div class="mb-3">
      <label for="difficulty" class="form-label">Dificuldade</label>
      <select class="form-select" id="difficulty" name="difficulty" required>
        <option value="easy" selected>Fácil</option>
        <option value="medium">Médio</option>
        <option value="hard">Difícil</option>
      </select>
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary">Salvar</button>
      <a href="/game-session" class="btn btn-secondary">Cancelar</a>
    </div>
  </form>
</div>

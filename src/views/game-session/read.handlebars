<div class="container mt-4" style="max-width: 600px">
  <div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h5 class="mb-0">Partida</h5>
      <span class="badge bg-secondary">{{gameSession.score}} pts</span>
    </div>
    <div class="card-body">
      <p class="card-text"><strong>Usuário:</strong> {{gameSession.userId}}</p>
      <p class="card-text"><strong>Pontuação:</strong> {{gameSession.score}}</p>
      <p class="card-text"><strong>Dificuldade:</strong> {{gameSession.difficulty}}</p>
    </div>
    <div class="card-footer d-flex gap-2">
      <a href="/game-session/update/{{gameSession.id}}" class="btn btn-warning btn-sm">Editar</a>
      <a href="/game-session" class="btn btn-secondary btn-sm">Voltar</a>
    </div>
  </div>
</div>
